# Cloudflare Workers — Static Assets headers
# https://developers.cloudflare.com/workers/static-assets/headers/

# ── Security headers (all responses) ──
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  X-DNS-Prefetch-Control: off
  # CSP. React islands load as external modules from /_astro (script-src 'self').
  # Astro also emits 3 tiny INLINE runtime scripts (the astro-island custom
  # element + Astro.load/Astro.only); instead of 'unsafe-inline' we pin their
  # exact SHA-256 hashes below, so script-src carries NO 'unsafe-inline'.
  # These hashes are Astro-version-specific — scripts/checkCspHashes.mjs runs in
  # CI after the build and fails if the built inline scripts no longer match, so
  # an Astro bump can't silently break island hydration in production.
  # style-src keeps 'unsafe-inline': Shiki emits per-token inline style="…"
  # attributes on code blocks (can't be hashed without 'unsafe-hashes'), and
  # securityheaders only flags 'unsafe-inline' in script-src, not style-src.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; object-src 'none'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'sha256-eIXWvAmxkr251LJZkjniEK5LcPF3NkapbJepohwYRIc=' 'sha256-SaCkFfPruIdTXT8/97JArQmGxiJAL2o4bBDvSgJ5y3Q=' 'sha256-QzWFZi+FLIx23tnm9SBU4aEgx4x8DsuASP07mfqol/c='; connect-src 'self'; manifest-src 'self'; frame-src 'none'

# ── Fingerprinted build output — cache hard (immutable) ──
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ── Agent / SEO text endpoints — 1h edge+browser cache ──
/llms.txt
  Cache-Control: public, max-age=3600
/llms-full.txt
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-0.xml
  Cache-Control: public, max-age=3600
