---
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { dicts, type Locale } from "@/lib/cv";

const { locale } = Astro.props as { locale: Locale };
const d = dicts[locale];

const accent = "text-[#0078d4] dark:text-[#3ca0e7]";
const card =
  "rounded-lg border border-border bg-body dark:border-darkmode-border dark:bg-darkmode-light";
const eyebrow =
  "font-secondary text-xs font-bold uppercase tracking-[0.12em] text-text-light";

// Language-neutral numbers; labels come from the dictionary.
const stats = [
  { num: "15+", label: d.stat_years_label },
  { num: "5+", label: d.stat_azure_label },
  { num: "4", label: d.stat_alz_label },
  { num: "26", label: d.stat_subscriptions_label },
  { num: "500K€+", label: d.stat_budget_label },
  { num: "35+", label: d.stat_trained_label },
];

// Company / logo / links are constant; the rest is translated.
const experiences = [
  {
    title: d.job1_title,
    company: "POST Luxembourg",
    logo: "/images/companies/post-logo.webp",
    meta: d.job1_meta,
    date: d.job1_date,
    context: d.job1_context,
    bullets: [
      d.job1_b1,
      d.job1_b2,
      d.job1_b3,
      d.job1_b4,
      d.job1_b5,
      d.job1_b6,
      d.job1_b7,
    ],
    links: [
      {
        url: "https://github.com/John6810/terraform-azurerm-modules",
        label: d.job1_link_github,
      },
    ],
  },
  {
    title: d.job2_title,
    company: "Alten",
    logo: "/images/companies/alten-logo.webp",
    meta: d.job2_meta,
    date: d.job2_date,
    context: d.job2_context,
    bullets: [d.job2_b1, d.job2_b2, d.job2_b3, d.job2_b4, d.job2_b5],
  },
  {
    title: d.job3_title,
    company: "Astorg",
    logo: "/images/companies/astorg-logo.webp",
    meta: d.job3_meta,
    date: d.job3_date,
    context: d.job3_context,
    bullets: [d.job3_b1, d.job3_b2, d.job3_b3, d.job3_b4, d.job3_b5],
  },
  {
    title: d.job4_title,
    company: "Guardian Industries",
    logo: "/images/companies/guardian-logo.webp",
    meta: d.job4_meta,
    date: d.job4_date,
    context: d.job4_context,
    bullets: [d.job4_b1, d.job4_b2, d.job4_b3, d.job4_b4],
  },
  {
    title: d.job5_title,
    company: "GMS-it",
    logo: "/images/companies/gms-it-logo.webp",
    meta: d.job5_meta,
    date: d.job5_date,
    context: d.job5_context,
    bullets: [d.job5_b1, d.job5_b2, d.job5_b3, d.job5_b4],
  },
  {
    title: d.job6_title,
    company: "Computacenter",
    logo: "/images/companies/computacenter-logo.webp",
    meta: d.job6_meta,
    date: d.job6_date,
    context: d.job6_context,
    bullets: [d.job6_b1, d.job6_b2, d.job6_b3],
  },
  {
    title: d.job7_title,
    company: "ETNIC",
    logo: "/images/companies/etnic-logo.webp",
    meta: d.job7_meta,
    date: d.job7_date,
    context: d.job7_context,
    bullets: [d.job7_b1, d.job7_b2, d.job7_b3],
  },
];

const skillCategories = [
  {
    emoji: "☁️",
    title: d.cat_cloud,
    skills: [
      { name: "Azure Landing Zone", icon: "/icons/azure-mg.svg", expert: true },
      {
        name: "Microsoft CAF / Azure Verified Modules",
        icon: "/icons/azure-mg.svg",
        expert: false,
      },
      {
        name: "AKS / Kubernetes",
        icon: "/icons/kubernetes.svg",
        expert: false,
      },
    ],
  },
  {
    emoji: "🔧",
    title: d.cat_iac,
    skills: [
      { name: "Terraform", icon: "/icons/terraform.svg", expert: true },
      { name: "Terragrunt", icon: "/icons/terragrunt.webp", expert: false },
      { name: "Argo CD / GitOps", icon: "/icons/argocd.svg", expert: false },
      {
        name: "Azure DevOps / GitHub Actions",
        icon: "/icons/azuredevops.svg",
        expert: false,
      },
    ],
  },
  {
    emoji: "🌐",
    title: d.cat_network,
    skills: [
      {
        name: "Hub-Spoke / Virtual WAN / ExpressRoute",
        icon: "/icons/vwan.svg",
        expert: true,
      },
      {
        name: "Palo Alto VM-Series",
        icon: "/icons/paloalto.svg",
        expert: false,
      },
      {
        name: "Defender for Cloud / Sentinel",
        icon: "/icons/defender.svg",
        expert: false,
      },
    ],
  },
  {
    emoji: "🔐",
    title: d.cat_identity,
    skills: [
      {
        name: "Entra ID / Conditional Access / PIM",
        icon: "/icons/ca.svg",
        expert: true,
      },
      { name: "Azure Policy / RBAC", icon: "/icons/policy.svg", expert: true },
      {
        name: "Key Vault / Workload Identity",
        icon: "/icons/keyvault.svg",
        expert: false,
      },
    ],
  },
  {
    emoji: "📊",
    title: d.cat_observ,
    skills: [
      {
        name: "Azure Monitor / Managed Prometheus / Grafana",
        icon: "/icons/monitor.svg",
        expert: false,
      },
      {
        name: "Microsoft 365 / Exchange Online / Intune",
        icon: "/icons/intune.svg",
        expert: false,
      },
      {
        name: "VMware vSphere · Cisco / Meraki SD-WAN",
        icon: "/icons/vmware.svg",
        expert: false,
      },
    ],
  },
];

const projects = [
  {
    title: d.proj1_title,
    tagline: d.proj1_tagline,
    desc: d.proj1_desc,
    tags: ["Terraform", "Azure", "AVM", "IaC", "GitHub Actions"],
    link: {
      url: "https://github.com/John6810/terraform-azurerm-modules",
      label: d.proj1_link,
    },
  },
  {
    title: d.proj2_title,
    tagline: d.proj2_tagline,
    desc: d.proj2_desc,
    tags: ["Python", "FastAPI", "Kubernetes", "ArgoCD", "Docker", "pytest"],
  },
  {
    title: d.proj3_title,
    tagline: d.proj3_tagline,
    desc: d.proj3_desc,
    tags: [
      "Kubernetes",
      "ArgoCD",
      "Traefik",
      "Prometheus",
      "MetalLB",
      "Sealed Secrets",
    ],
  },
];

const certsDone = [
  "AZ-104 — Azure Administrator",
  "AZ-500 — Azure Security Engineer",
  "AZ-700 — Azure Network Engineer",
  "HashiCorp Terraform Associate",
];
const certsWip = [
  "AZ-305 — Azure Solutions Architect Expert",
  "AWS Solutions Architect Associate",
];
const languages = [
  { flag: "/icons/flag-fr.svg", label: d.lang_fr },
  { flag: "/icons/flag-gb.svg", label: d.lang_en },
  { flag: "/icons/flag-jp.svg", label: d.lang_jp },
];
---

<section class="section-sm">
  <div class="container">
    <div class="row justify-center">
      <div class="lg:col-10 flex flex-col gap-6">
        <!-- HERO -->
        <div id="about" class={`${card} p-6 md:p-8`}>
          <div class="flex flex-col items-start gap-6 sm:flex-row sm:gap-10">
            <div class="flex flex-none flex-col items-center gap-4">
              <img
                src="/images/avatar.jpg"
                alt="Jonathan Aerts"
                width="208"
                height="208"
                loading="eager"
                class="h-28 w-28 rounded-lg object-cover sm:h-40 sm:w-40"
              />
              <div class="flex gap-2">
                <a
                  href="https://github.com/John6810"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="GitHub"
                  class="grid h-9 w-9 place-items-center rounded border border-border text-text-light transition hover:text-[#0078d4] dark:border-darkmode-border"
                >
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.77 1.06.77 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
                    ></path></svg
                  >
                </a>
                <a
                  href="https://linkedin.com/in/jaerts085"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="LinkedIn"
                  class="grid h-9 w-9 place-items-center rounded border border-border text-text-light transition hover:text-[#0078d4] dark:border-darkmode-border"
                >
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      d="M4.98 3.5a2.5 2.5 0 1 1 .02 5 2.5 2.5 0 0 1-.02-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.06c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.07 1.4-2.07 2.86V21h-4V9z"
                    ></path></svg
                  >
                </a>
              </div>
            </div>

            <div class="flex w-full flex-col gap-4">
              <div
                class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between"
              >
                <div>
                  <h1 class="text-h2-sm md:text-h2">Jonathan Aerts</h1>
                  <p class="mt-1 font-secondary text-text-light">
                    {d.hero_role}
                  </p>
                </div>
                <LanguageSwitcher current={locale} />
              </div>

              <div class="grid gap-x-8 gap-y-1 text-sm sm:grid-cols-2">
                <div>
                  <span
                    class="font-semibold text-text-dark dark:text-darkmode-text-dark"
                    >{d.hero_label_email}</span
                  >
                  <a
                    href="mailto:hi@jonathan-aerts.dev"
                    class="hover:text-[#0078d4] hover:underline"
                    >hi@jonathan-aerts.dev</a
                  >
                </div>
                <div>
                  <span
                    class="font-semibold text-text-dark dark:text-darkmode-text-dark"
                    >{d.hero_label_from}</span
                  >
                  {d.hero_value_from}
                </div>
                <div class="inline-flex items-center gap-1.5">
                  <span
                    class="font-semibold text-text-dark dark:text-darkmode-text-dark"
                    >{d.hero_label_currently}</span
                  >
                  <img
                    src="/images/companies/post-logo.webp"
                    alt="POST Luxembourg"
                    height="16"
                    class="inline-block h-4 w-auto"
                    loading="lazy"
                  />
                  {d.hero_value_currently}
                </div>
                <div class="inline-flex flex-wrap items-center gap-1.5">
                  <span
                    class="font-semibold text-text-dark dark:text-darkmode-text-dark"
                    >{d.hero_label_languages}</span
                  >
                  <img
                    src="/icons/flag-fr.svg"
                    alt=""
                    width="16"
                    height="12"
                    class="inline-block h-3 w-4 rounded-[2px] object-cover"
                  /> FR
                  <span class="text-text-light">·</span>
                  <img
                    src="/icons/flag-gb.svg"
                    alt=""
                    width="16"
                    height="12"
                    class="inline-block h-3 w-4 rounded-[2px] object-cover"
                  /> EN
                  <span class="text-text-light">·</span>
                  <img
                    src="/icons/flag-jp.svg"
                    alt=""
                    width="16"
                    height="12"
                    class="inline-block h-3 w-4 rounded-[2px] object-cover"
                  /> JP
                </div>
              </div>

              <p
                class="text-sm leading-relaxed sm:text-base"
                set:html={d.hero_desc}
              />

              <div class="flex flex-wrap gap-2">
                <span
                  class="rounded border border-border bg-light px-2.5 py-1 text-xs font-medium dark:border-darkmode-border dark:bg-darkmode-body"
                  >Azure Landing Zone</span
                >
                <span
                  class="rounded border border-border bg-light px-2.5 py-1 text-xs font-medium dark:border-darkmode-border dark:bg-darkmode-body"
                  >Terraform · Terragrunt</span
                >
                <span
                  class="rounded border border-border bg-light px-2.5 py-1 text-xs font-medium dark:border-darkmode-border dark:bg-darkmode-body"
                  >GitOps · Platform Engineering</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- STATS -->
        <div class={`${card} overflow-hidden`}>
          <div
            class="grid grid-cols-2 divide-x divide-y divide-border sm:grid-cols-3 lg:grid-cols-6 dark:divide-darkmode-border"
          >
            {
              stats.map((s) => (
                <div class="flex flex-col items-center px-4 py-6 text-center">
                  <div class={`text-3xl font-extrabold leading-none ${accent}`}>
                    {s.num}
                  </div>
                  <div class="mt-2 text-[13px] leading-snug text-text-light text-balance">
                    {s.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- EXPÉRIENCE -->
        <div id="experience" class={`${card} p-6 md:p-8`}>
          <h2 class="text-h3-sm md:text-h3">{d.section_experience}</h2>
          <div class="mt-8 flex flex-col gap-8">
            {
              experiences.map((job) => (
                <article class="border-l-2 border-border pl-5 dark:border-darkmode-border">
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <h3 class="flex items-center gap-2 text-h4">
                      {job.logo && (
                        <img
                          src={job.logo}
                          alt={job.company}
                          height="22"
                          class="inline-block h-[22px] w-auto rounded-[3px]"
                          loading="lazy"
                        />
                      )}
                      <span>{job.title}</span>
                    </h3>
                    <span class="font-secondary text-xs font-bold uppercase tracking-wide text-text-light">
                      {job.date}
                    </span>
                  </div>
                  <p class={`mt-1 font-semibold ${accent}`}>
                    {job.company}{" "}
                    <span class="font-normal text-text-light">
                      · {job.meta}
                    </span>
                  </p>
                  <p class="mt-2 text-sm leading-relaxed text-text-light">
                    {job.context}
                  </p>
                  <ul class="mt-3 flex flex-col gap-2">
                    {job.bullets.map((b) => (
                      <li class="relative pl-5 text-sm leading-relaxed">
                        <span class="absolute left-0 top-[0.45em] h-1.5 w-1.5 rounded-full bg-[#0078d4]" />
                        <span set:html={b} />
                      </li>
                    ))}
                  </ul>
                  {job.links && (
                    <div class="mt-3 flex flex-col gap-1">
                      {job.links.map((l) => (
                        <a
                          href={l.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class={`text-[13px] font-medium ${accent} hover:underline`}
                        >
                          {l.label}
                        </a>
                      ))}
                    </div>
                  )}
                </article>
              ))
            }
          </div>
        </div>

        <!-- SKILLS -->
        <div id="skills" class={`${card} p-6 md:p-8`}>
          <h2 class="text-h3-sm md:text-h3">{d.section_skills}</h2>
          <div class="mt-8 flex flex-col gap-7">
            {
              skillCategories.map((cat) => (
                <div>
                  <h4 class="mb-3 flex items-center gap-2 font-secondary text-xs font-bold uppercase tracking-[0.12em] text-text-light">
                    <>
                      <span aria-hidden="true">{cat.emoji}</span>
                      <span>{cat.title}</span>
                    </>
                  </h4>
                  <div class="grid grid-cols-1 gap-x-6 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
                    {cat.skills.map((s) => (
                      <div class="flex flex-col gap-0.5">
                        <div class="flex items-center gap-2">
                          <img
                            src={s.icon}
                            alt=""
                            width="20"
                            height="20"
                            class="h-5 w-5 flex-none object-contain"
                            loading="lazy"
                          />
                          <span class="text-sm font-medium text-text-dark dark:text-darkmode-text-dark">
                            {s.name}
                          </span>
                        </div>
                        <span
                          class={`pl-7 font-secondary text-[10px] font-bold uppercase tracking-[0.1em] ${s.expert ? accent : "text-text-light"}`}
                        >
                          {s.expert ? d.level_expert : d.level_avance}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
            <div>
              <h4
                class="mb-3 font-secondary text-xs font-bold uppercase tracking-[0.12em] text-text-light"
              >
                {d.skills_learning}
              </h4>
              <span
                class="inline-flex items-center gap-2 rounded border border-border bg-light px-2.5 py-1 text-sm font-medium dark:border-darkmode-border dark:bg-darkmode-body"
              >
                <img
                  src="/icons/aws.svg"
                  alt=""
                  width="16"
                  height="16"
                  class="h-4 w-4"
                  loading="lazy"
                />
                {d.learning_aws}
              </span>
            </div>
          </div>
        </div>

        <!-- PROJETS -->
        <div id="projects" class={`${card} p-6 md:p-8`}>
          <h2 class="text-h3-sm md:text-h3">{d.section_projects}</h2>
          <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {
              projects.map((p) => (
                <article class="flex flex-col gap-3 rounded-lg border border-border bg-light p-5 dark:border-darkmode-border dark:bg-darkmode-body">
                  <header class="flex flex-col gap-1">
                    <h3 class="text-h5">{p.title}</h3>
                    <p
                      class={`font-secondary text-[11px] font-bold uppercase tracking-[0.06em] ${accent}`}
                    >
                      {p.tagline}
                    </p>
                  </header>
                  <p class="text-sm leading-relaxed text-text-light">
                    {p.desc}
                  </p>
                  <div class="mt-auto flex flex-wrap gap-1.5 pt-2">
                    {p.tags.map((tg) => (
                      <span class="rounded border border-border bg-body px-2 py-0.5 text-xs dark:border-darkmode-border dark:bg-darkmode-light">
                        {tg}
                      </span>
                    ))}
                  </div>
                  {p.link && (
                    <a
                      href={p.link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class={`text-[13px] font-medium ${accent} hover:underline`}
                    >
                      {p.link.label}
                    </a>
                  )}
                </article>
              ))
            }
          </div>
        </div>

        <!-- FORMATION -->
        <div id="education" class={`${card} p-6 md:p-8`}>
          <h2 class="text-h3-sm md:text-h3">{d.section_education}</h2>
          <div class="mt-8 grid gap-8 sm:grid-cols-2">
            <div class="flex flex-col gap-2">
              <span class={eyebrow}>{d.edu_eb_diplome}</span>
              <h3 class="text-h5">{d.edu_degree_title}</h3>
              <p class="text-sm text-text-light">{d.edu_degree_school}</p>
            </div>
            <div class="flex flex-col gap-2">
              <span class={eyebrow}>{d.edu_eb_langs}</span>
              <ul class="mt-1 flex flex-col gap-2 text-sm">
                {
                  languages.map((l) => (
                    <li class="flex items-center gap-3">
                      <img
                        src={l.flag}
                        alt=""
                        width="16"
                        height="12"
                        class="h-3 w-4 flex-none rounded-[2px] object-cover"
                        loading="lazy"
                      />
                      <span>{l.label}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div class="flex flex-col gap-2">
              <span class={eyebrow}>{d.edu_eb_certs_done}</span>
              <ul class="mt-1 flex flex-col gap-2 text-sm">
                {
                  certsDone.map((c) => (
                    <li class="flex items-center gap-2">
                      <>
                        <span class="text-[#16a34a]">✓</span>
                        <span>{c}</span>
                      </>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div class="flex flex-col gap-2">
              <span class={eyebrow}>{d.edu_eb_certs_wip}</span>
              <ul class="mt-1 flex flex-col gap-2 text-sm">
                {
                  certsWip.map((c) => (
                    <li class="flex items-center gap-2">
                      <>
                        <span class={accent}>→</span>
                        <span>{c}</span>
                      </>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- CONTACT -->
        <div id="contact" class={`${card} p-6 md:p-8`}>
          <h2 class="text-h3-sm md:text-h3">{d.section_contact}</h2>
          <p
            class="mt-4 max-w-2xl text-sm leading-relaxed text-text-light sm:text-base"
          >
            {d.contact_desc}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="mailto:hi@jonathan-aerts.dev" class="btn btn-primary"
              >✉ hi@jonathan-aerts.dev</a
            >
            <a
              href="https://linkedin.com/in/jaerts085"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline-primary">LinkedIn</a
            >
            <a href="/blog" class="btn btn-outline-primary"
              >{d.contact_cta_blog}</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
