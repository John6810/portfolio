---
---
<section id="hero" class="relative py-20">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <div class="aspect-video relative rounded-xl overflow-hidden mb-6">
          <picture>
            <source srcset={`${import.meta.env.BASE_URL}images/Panel.webp`} type="image/webp" />
            <img
              src={`${import.meta.env.BASE_URL}images/Panel.png`}
              alt="Jonathan Aerts — Cloud Solutions Architect portfolio banner"
              class="w-full h-full object-cover object-top"
              width="800" height="448"
              loading="eager"
              decoding="async"
            />
          </picture>
        </div>
        <div class="inline-flex items-center gap-2 bg-[#0d1320] border border-cyan-500/20 rounded-full px-4 py-2 text-sm">
          <span class="w-2.5 h-2.5 bg-green-400 rounded-full animate-pulse"></span>
          <span data-i18n="status">Disponible — Ouvert aux opportunités</span>
        </div>
      </div>
      <div>
        <h1 class="font-[Orbitron] text-4xl lg:text-5xl font-bold text-cyan-400 mb-2">Jonathan Aerts</h1>
        <h2 class="font-[Orbitron] text-lg text-cyan-300 mb-4"><span id="typingText" class="typing-cursor">Cloud Solutions Architect</span></h2>
        <p class="text-gray-300 mb-6 leading-relaxed" data-i18n="hero_desc">Cloud Solutions Architect avec 15+ ans d'expérience IT et 5+ ans focalisés sur les environnements Azure enterprise. Spécialisé dans la conception et le déploiement d'Azure Landing Zones de A à Z.</p>
        <div class="space-y-2 mb-6 text-sm text-gray-400">
          <div>📍 <span data-i18n="hero_location">Belgique · Luxembourg · Ouvert à la relocation : Japon 🇯🇵</span></div>
          <div>🏢 POST Luxembourg — Cloud Solutions Architect</div>
          <div>📧 <a data-email class="hover:text-cyan-400 transition-colors">[email protected]</a></div>
          <div>🔗 <a href="https://linkedin.com/in/jaerts085/" target="_blank" rel="noopener noreferrer" class="hover:text-cyan-400 transition-colors">linkedin.com/in/jaerts085/</a></div>
          <div>💻 <a href="https://github.com/John6810" target="_blank" rel="noopener noreferrer" class="hover:text-cyan-400 transition-colors">github.com/John6810</a></div>
          <div>🌐 <span data-i18n="hero_langs">Français (natif) · Anglais (C1) · 日本語 (JLPT N5, objectif N1)</span></div>
        </div>
        <div class="flex gap-4">
          <a href="#contact" class="btn-primary" data-i18n="btn_contact">📧 Me Contacter</a>
          <a href="#experience" class="btn-outline" data-i18n="btn_experience">💼 Mon Expérience</a>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-8">
      <div class="stat-card"><div class="stat-number">15+</div><div class="text-xs text-gray-400 mt-1" data-i18n="stat_years">ans · Sysadmin → Cloud Architect</div></div>
      <div class="stat-card"><div class="stat-number">5+</div><div class="text-xs text-gray-400 mt-1" data-i18n="stat_cloud">ans · Azure enterprise · Landing Zones from scratch</div></div>
      <div class="stat-card"><div class="stat-number">50+</div><div class="text-xs text-gray-400 mt-1" data-i18n="stat_subs">Subscriptions Azure · gouvernance end-to-end</div></div>
      <div class="stat-card"><div class="stat-number" data-i18n="stat_budget_num">+€500K</div><div class="text-xs text-gray-400 mt-1" data-i18n="stat_budget">Budget Azure annuel géré</div></div>
      <div class="stat-card"><div class="stat-number">35+</div><div class="text-xs text-gray-400 mt-1" data-i18n="stat_trained">ingénieurs formés · Azure, Terraform & Governance</div></div>
      <div class="stat-card"><div class="stat-number">4</div><div class="text-xs text-gray-400 mt-1" data-i18n="stat_alz">Azure Landing Zones from scratch</div></div>
    </div>
  </div>
</section>

<script>
  import '../scripts/typing';
</script>