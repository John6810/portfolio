---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/sora/600.css';
import '@fontsource/sora/700.css';
import '../styles/recruiter.css';
import BaseHead from '../components/BaseHead.astro';
import Analytics from '../components/Analytics.astro';
---

<!doctype html>
<html lang="fr">
<head>
  <BaseHead
    title="Jonathan Aerts — Cloud Solutions Architect | Azure Landing Zone | Belgium Luxembourg"
    description="Cloud Solutions Architect 15+ ans IT. Azure Landing Zones from scratch, Terraform/Terragrunt, gouvernance enterprise. Belgium/Luxembourg."
    canonicalURL="https://jonathan-aerts.dev/recruiter"
    themeColor="#f8fafc"
  />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' gc.zgo.at; img-src 'self' data:; font-src 'self'; connect-src 'self' *.goatcounter.com" />
</head>

<body>
  <a href="#main" class="skip-to-content">Skip to content</a>

  <!-- NAV -->
  <header>
  <nav class="topnav">
    <span class="topnav-name">Jonathan Aerts</span>
    <div class="topnav-links">
      <a href="#experience" data-i18n="nav_experience">Expérience</a>
      <a href="#skills" data-i18n="nav_skills">Compétences</a>
      <a href="#contact" class="btn-contact" data-i18n="r_nav_contact">Me contacter</a>
    </div>
    <div class="lang-switcher" role="group" aria-label="Change language">
      <button id="btn-fr" type="button" class="r-lang-btn" data-lang="fr" aria-label="Français" aria-pressed="true">FR</button>
      <button id="btn-en" type="button" class="r-lang-btn" data-lang="en" aria-label="English" aria-pressed="false">EN</button>
      <button id="btn-jp" type="button" class="r-lang-btn" data-lang="jp" aria-label="日本語" aria-pressed="false">JP</button>
    </div>
    <a href="/" class="topnav-back" data-i18n="r_nav_back">← Accueil</a>
  </nav>
  </header>

  <main id="main">

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-tag" data-i18n="status">Disponible — Ouvert aux opportunités</div>
          <h1>Jonathan Aerts</h1>
          <p class="hero-title">Cloud Solutions Architect  •  Microsoft Azure  •  IaC / Terraform</p>
          <p class="hero-desc" data-i18n="hero_desc">Cloud Solutions Architect avec 15+ ans d'expérience IT et 5+ ans focalisés sur les environnements Azure enterprise. Spécialisé dans la conception et le déploiement d'Azure Landing Zones de A à Z — gouvernance, networking multi-région, et automatisation complète via Terraform/Terragrunt.</p>
          <div class="hero-meta">
            <span data-i18n="r_hero_location">📍 Belgique · Luxembourg · Ouvert à la relocation : Japon 🇯🇵</span>
            <span>🏢 POST Luxembourg</span>
            <span data-email-text>✉️ [email protected]</span>
          </div>
          <div class="hero-actions">
            <a href="#contact" class="btn-primary" data-i18n="r_nav_contact">Me contacter</a>
            <a href="/full" class="btn-secondary" data-i18n="r_btn_full">Site complet →</a>
          </div>
        </div>
        <div class="hero-photo">
          <picture>
            <source srcset="/images/avatar-sm.webp" type="image/webp" />
            <img src="/images/avatar.jpg" alt="Photo de profil de Jonathan Aerts, Cloud Solutions Architect" width="134" height="134" loading="eager" fetchpriority="high" />
          </picture>
        </div>
      </div>
    </section>

    <!-- CHIFFRES CLÉS -->
    <section class="stats">
      <div class="stats-inner">
        <div class="stat">
          <span class="stat-num">15+</span>
          <span class="stat-label" data-i18n="stat_years">ans · Sysadmin → Cloud Architect</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">5+</span>
          <span class="stat-label" data-i18n="stat_cloud">ans · Azure enterprise · Landing Zones from scratch</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">50+</span>
          <span class="stat-label" data-i18n="stat_subs">Subscriptions Azure · gouvernance end-to-end</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num" data-i18n="stat_budget_num">+€500K</span>
          <span class="stat-label" data-i18n="stat_budget">Budget Azure annuel géré</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">35+</span>
          <span class="stat-label" data-i18n="stat_trained">ingénieurs formés · Azure, Terraform & Governance</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">4</span>
          <span class="stat-label" data-i18n="stat_alz">Azure Landing Zones from scratch</span>
        </div>
      </div>
    </section>

    <!-- POINTS FORTS -->
    <section class="highlights">
      <div class="section-inner">
        <h2 data-i18n="section_highlights">Points Forts Professionnels</h2>
        <div class="highlights-grid">
          <div class="hl-card">
            <span class="hl-icon">🏗️</span>
            <h3>Azure Landing Zone</h3>
            <p data-i18n="hl1">Built from scratch, Enterprise-Scale, CAF</p>
          </div>
          <div class="hl-card">
            <span class="hl-icon">⚡</span>
            <h3>IaC Zero-Touch</h3>
            <p data-i18n="hl2">Terraform/Terragrunt, 14 subscriptions automatisées</p>
          </div>
          <div class="hl-card">
            <span class="hl-icon">🌐</span>
            <h3 data-i18n="r_hl3_title">Multi-Région</h3>
            <p data-i18n="hl3">Germany West Central + France Central, VWAN</p>
          </div>
          <div class="hl-card">
            <span class="hl-icon">🔒</span>
            <h3>Security & Governance</h3>
            <p data-i18n="hl4">Defender, Sentinel, CIS, ISO 27001, RBAC, PIM</p>
          </div>
        </div>
      </div>
    </section>

    <!-- COMPÉTENCES -->
    <section class="skills" id="skills">
      <div class="section-inner">
        <h2 data-i18n="r_section_skills">Compétences Techniques</h2>
        <div class="skills-grid">
          <div class="skills-group">
            <h3 data-i18n="skills_cloud">Cloud Architecture</h3>
            <ul>
              <li><span>Azure Landing Zone / CAF</span><span class="level expert" data-i18n="level_expert">Expert</span></li>
              <li><span>Multi-region Design</span><span class="level expert" data-i18n="level_expert">Expert</span></li>
              <li><span>Hub-Spoke / Virtual WAN</span><span class="level expert" data-i18n="level_expert">Expert</span></li>
              <li><span>AWS</span><span class="level learning" data-i18n="level_learning">En cours</span></li>
            </ul>
          </div>
          <div class="skills-group">
            <h3 data-i18n="skills_iac">IaC & Automation</h3>
            <ul>
              <li><span>Terraform</span><span class="level expert" data-i18n="level_expert">Expert</span></li>
              <li><span>Terragrunt</span><span class="level advanced" data-i18n="level_advanced">Avancé</span></li>
              <li><span>Azure DevOps / CI-CD</span><span class="level advanced" data-i18n="level_advanced">Avancé</span></li>
              <li><span>PowerShell</span><span class="level advanced" data-i18n="level_advanced">Avancé</span></li>
            </ul>
          </div>
          <div class="skills-group">
            <h3 data-i18n="skills_security">Security & Identity</h3>
            <ul>
              <li><span>Defender for Cloud / Sentinel</span><span class="level advanced" data-i18n="level_advanced">Avancé</span></li>
              <li><span>Azure Policy / RBAC / PIM</span><span class="level expert" data-i18n="level_expert">Expert</span></li>
              <li><span>Entra ID / Conditional Access</span><span class="level expert" data-i18n="level_expert">Expert</span></li>
              <li><span>CIS / ISO 27001</span><span class="level advanced" data-i18n="level_advanced">Avancé</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- EXPÉRIENCE -->
    <section class="experience" id="experience">
      <div class="section-inner">
        <h2 data-i18n="section_experience">Expérience Professionnelle</h2>

        <div class="job">
          <div class="job-header">
            <div>
              <h3 data-i18n="job1_title">Cloud Solutions Architect — Azure Landing Zone & Terraform</h3>
              <p class="job-company">POST Luxembourg — Luxembourg</p>
            </div>
            <span class="job-date" data-i18n="job1_date">Août 2024 – Présent</span>
          </div>
          <p class="job-context" data-i18n="job1_context">Rejoint pour concevoir et implémenter la fondation Azure de POST from scratch. Aucun Landing Zone, modèle de gouvernance ou pratique IaC n'existait.</p>
          <ul>
            <li data-i18n="job1_b1">Conçu et déployé l'Azure Landing Zone (Enterprise-Scale) via Microsoft CAF, ALZ modules, AVM-PTN-ALZ et AMBA.</li>
            <li data-i18n="job1_b2">IaC from scratch — pipeline Terraform/Terragrunt DRY sur 14 subscriptions depuis un seul codebase.</li>
            <li data-i18n="job1_b3">Architecture multi-région (Germany West Central + France Central) avec VWAN et Palo Alto VM-Series.</li>
            <li data-i18n="job1_b4">Intégré Defender for Cloud, Azure Policies, RBAC, PIM, CMK, Log Analytics et Sentinel.</li>
            <li data-i18n="job1_b7">Conception en cours d'un AWS Landing Zone multi-compte (Control Tower, SCPs, IaC).</li>
          </ul>
          <div class="job-tags">
            <span>Azure Landing Zone</span><span>Terraform</span><span>Terragrunt</span><span>Virtual WAN</span><span>Palo Alto</span><span>Sentinel</span><span>AKS</span><span>AWS</span>
          </div>
          <a href="https://www.microsoft.com/en/customers/story/24351-post-luxembourg-azure"
             target="_blank" rel="noopener noreferrer"
             class="job-ref">
            🔗 Microsoft Customer Story — POST Luxembourg moves core banking to Azure
          </a>
        </div>

        <div class="job">
          <div class="job-header">
            <div>
              <h3 data-i18n="job2_title">Cloud Architect — M365 & Azure Migration</h3>
              <p class="job-company">Alten — <span data-i18n="job2_client">Mission: Aéroport de Luxembourg</span></p>
            </div>
            <span class="job-date" data-i18n="job2_date">Août 2023 – Juil 2024</span>
          </div>
          <p class="job-context" data-i18n="job2_context">Modernisation complète de l'infrastructure IT de l'Aéroport du Luxembourg.</p>
          <ul>
            <li data-i18n="job2_b1">Migration de 500+ boîtes mail Exchange on-prem vers Microsoft 365.</li>
            <li data-i18n="job2_b2">Baselines de sécurité CIS : Conditional Access, MFA, Compliance Center hardening.</li>
            <li data-i18n="job2_b3">Premier Azure Landing Zone de l'aéroport via Terraform avec modules réutilisables.</li>
          </ul>
          <div class="job-tags">
            <span>Azure</span><span>Terraform</span><span>Microsoft 365</span><span>Entra ID</span><span>CIS Baselines</span>
          </div>
        </div>

        <div class="job">
          <div class="job-header">
            <div>
              <h3 data-i18n="job3_title">Cloud & Infrastructure Architect</h3>
              <p class="job-company">Astorg (Private Equity) — Luxembourg</p>
            </div>
            <span class="job-date" data-i18n="job3_date">Sep 2021 – Juil 2023</span>
          </div>
          <p class="job-context" data-i18n="job3_context">Modernisation globale Astorg (250 utilisateurs, 6 bureaux : LU, FR, UK, DE, IT, US). Migration AD 2008 vers architecture hybride Azure + Entra ID.</p>
          <ul>
            <li data-i18n="job3_b1">Programme de modernisation sur 6 bureaux internationaux avec déploiements on-site.</li>
            <li data-i18n="job3_b2">Cisco Meraki SD-WAN pour la connectivité inter-sites.</li>
            <li data-i18n="job3_b3">Intégration on-prem/Azure et modules Terraform from scratch.</li>
            <li data-i18n="job3_b5">Gouvernance RBAC/PIM/Policy alignée CIS, ISO 27001, CSSF. Budget ~€500K géré.</li>
          </ul>
          <div class="job-tags">
            <span>Azure</span><span>Terraform</span><span>Cisco Meraki SD-WAN</span><span>Intune</span><span>ISO 27001</span>
          </div>
        </div>

        <details class="job-previous">
          <summary data-i18n="r_earlier_title">Expériences précédentes (2007–2021)</summary>
          <div class="job-prev-list">
            <div class="job-prev-item">
              <span class="job-prev-title" data-i18n="job4_title">IT/OT System Administrator</span>
              <span class="job-prev-company">Guardian Industries — Luxembourg</span>
              <span class="job-prev-date">2019–2021</span>
            </div>
            <div class="job-prev-item">
              <span class="job-prev-title" data-i18n="earlier1_title">System Engineer — M365 & Infrastructure</span>
              <span class="job-prev-company">GMS-IT, Luxembourg</span>
              <span class="job-prev-date">2016–2019</span>
            </div>
            <div class="job-prev-item">
              <span class="job-prev-title" data-i18n="earlier2_title">VMware Consultant — Global Virtualization</span>
              <span class="job-prev-company">Computacenter — TI Automotive, Liège</span>
              <span class="job-prev-date">2014–2016</span>
            </div>
            <div class="job-prev-item">
              <span class="job-prev-title" data-i18n="earlier3_title">System & Network Administrator</span>
              <span class="job-prev-company">ETNIC — Fédération Wallonie-Bruxelles</span>
              <span class="job-prev-date">2007–2013</span>
            </div>
          </div>
        </details>

      </div>
    </section>

    <!-- FORMATION & CERTS -->
    <section class="education">
      <div class="section-inner">
        <h2 data-i18n="r_section_edu">Formation & Certifications</h2>
        <div class="edu-grid">
          <div class="edu-card">
            <h3 data-i18n="edu_degree">Bachelor — Computer Technology / Systems Technology</h3>
            <p>Haute École de la Province de Liège, Belgique · 2003–2007</p>
          </div>
          <div class="edu-card">
            <h3 data-i18n="edu_certs_obtained_title">Certifications Obtenues</h3>
            <div class="cert-list">
              <span class="cert done">AZ-104 — Azure Administrator</span>
              <span class="cert done">HashiCorp Terraform Associate</span>
            </div>
          </div>
          <div class="edu-card">
            <h3 data-i18n="edu_certs_wip_title">En cours / À venir</h3>
            <div class="cert-list">
              <span class="cert upcoming">AZ-305 — Azure Solutions Architect Expert</span>
              <span class="cert upcoming">AZ-700 — Network Engineer</span>
              <span class="cert upcoming">AWS Solutions Architect Associate</span>
            </div>
          </div>
          <div class="edu-card">
            <h3 data-i18n="edu_langs_title">Langues</h3>
            <div class="lang-list">
              <span data-i18n="r_lang_fr">🇫🇷 Français — Natif</span>
              <span data-i18n="r_lang_en">🇬🇧 Anglais — C1 courant</span>
              <span data-i18n="r_lang_jp">🇯🇵 日本語 — En apprentissage actif</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact" id="contact">
      <div class="section-inner contact-inner">
        <div class="contact-text">
          <h2 data-i18n="r_contact_title">Disponible pour de nouvelles opportunités</h2>
          <p data-i18n="contact_desc">Disponible pour des rôles Cloud Architect, Principal Engineer ou Customer Success Engineer chez un hyperscaler (Microsoft, AWS, HashiCorp) ou en environnement enterprise.</p>
        </div>
        <div class="contact-cards">
          <a data-email class="contact-card" aria-label="Envoyer un email">
            <span class="contact-icon">✉️</span>
            <span>[email protected]</span>
          </a>
          <a href="https://linkedin.com/in/jaerts085/" target="_blank" rel="noopener noreferrer" class="contact-card">
            <span class="contact-icon">🔗</span>
            <span>linkedin.com/in/jaerts085</span>
          </a>
          <div class="contact-card no-link">
            <span class="contact-icon">📍</span>
            <span data-i18n="hero_location">Belgique · Luxembourg</span>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <span>© 2025 Jonathan Aerts</span>
    <div class="footer-links">
      <a href="/" data-i18n="r_footer_home">← Accueil</a>
      <a href="/full" data-i18n="r_footer_full">Site complet</a>
    </div>
  </footer>

</body>
</html>

<script>
  import '../scripts/i18n';
</script>
<Analytics />
